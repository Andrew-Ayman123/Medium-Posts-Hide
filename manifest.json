{
  "manifest_version": 3,
  "default_locale": "en",
  "name": "Medium Recommended Memeber Posts Filter",
  "version": "1.0",
  "description": "Hide Recommended Memeber Posts from Medium Feed",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "*://*.medium.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Medium Feed Filter",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.medium.com/*"
      ],
      "js": [
        "content-bridge.js"
      ],
      "run_at": "document_start",
      "world": "ISOLATED"
    },
    {
      "matches": [
        "*://*.medium.com/*"
      ],
      "js": [
        "interceptor.js"
      ],
      "run_at": "document_start",
      "world": "MAIN"
    }
  ]
}